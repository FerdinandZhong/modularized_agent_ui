# Production environment variables template
# Copy to .env.production.local for local testing, or set in CML Application settings.
#
# Variables prefixed NEXT_PUBLIC_ are baked into the client bundle at build time.
# All others are server-side only (available in Next.js API routes and server components).

# ── Required for standalone deployment ───────────────────────────────────────

# URL of the CAI Agent Studio workflow backend
# If set alongside WORKFLOW_API_KEY, the connect page is skipped automatically.
WORKFLOW_BACKEND_URL=https://your-workflow-backend.ml.example.cloudera.site

# API key for authenticating with the workflow backend
WORKFLOW_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Base path if the app is served under a subpath (e.g. /agent-ui)
# Must match the --base-path used at build time.
NEXT_PUBLIC_BASE_PATH=

# Disable Next.js telemetry (recommended for air-gapped CML environments)
NEXT_TELEMETRY_DISABLED=1

# ── Injected automatically by CML ─────────────────────────────────────────────
# CDSW_APP_PORT      — port CAI routes traffic to (typically 8080)
# CDSW_DOMAIN        — platform domain used for DNS
# CDSW_PROJECT_ID    — project identifier
# CDSW_ENGINE_ID     — engine/session identifier
